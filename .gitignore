# --------------------------------------------------
# Dependencies
# --------------------------------------------------
node_modules/

# Package manager caches
.npm/
.pnpm-store/
.yarn/

# --------------------------------------------------
# Environment variables and secrets
# --------------------------------------------------
.env
.env.*
!.env.example
!.env.template

# Local secret/config variants
*.local

# --------------------------------------------------
# Logs and debug files
# --------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime/process manager logs and PIDs
pids/
*.pid
*.pid.lock

# --------------------------------------------------
# Build and generated output
# --------------------------------------------------
dist/
build/
out/
tmp/
temp/
.cache/

# Coverage reports
coverage/
.nyc_output/

# Compiled/bundled JS maps and minified assets (optional)
*.min.js
*.min.css

# --------------------------------------------------
# Databases and local data dumps
# --------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal
dump/
mongodb-dump/

# --------------------------------------------------
# Testing artifacts
# --------------------------------------------------
test-results/
playwright-report/
jest-stare/

# --------------------------------------------------
# Editor and IDE settings
# --------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

.idea/
*.iml

# Vim/Neovim swap files
*.swp
*.swo

# --------------------------------------------------
# OS-specific files
# --------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?

# --------------------------------------------------
# Misc
# --------------------------------------------------
*.tgz
*.tar
*.zip

